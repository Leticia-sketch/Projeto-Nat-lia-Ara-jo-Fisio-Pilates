{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist"
  },
  "include": [
    "controllers/**/*",
    "models/**/*",
    "routes/**/*",
    "database/**/*",
    "server.ts"
  ],
  "exclude": ["node_modules", "dist"]
}