###

### ==================
### SERVIÇOS
### ==================

### GET - Buscar serviços
GET http://localhost:3000/servicos

###

### POST - Criar serviço
POST http://localhost:3000/servicos
Content-Type: application/json

{
  "titulo": "Novo Serviço",
  "img": "img/exemplo.jpeg",
  "texto": "Descrição do novo serviço."
}

###

### PUT - Atualizar serviço
PUT http://localhost:3000/servicos/1
Content-Type: application/json

{
  "titulo": "Método Schroth",
  "img": "img/minipa3.jpeg",
  "texto": "Esse Método corrige a coluna em três dimensões."
}

###

### DELETE - Deletar serviço
DELETE http://localhost:3000/servicos/1

###

### PUT - Caso inválido (id inexistente)
PUT http://localhost:3000/servicos/9999
Content-Type: application/json

{
  "titulo": "Teste inválido",
  "img": "",
  "texto": ""
}

###

### ==================
### PLANOS
### ==================

### GET - Buscar planos
GET http://localhost:3000/planos

###

### POST - Criar plano
POST http://localhost:3000/planos
Content-Type: application/json

{
  "titulo": "Novo Plano",
  "preco": "R$ 200",
  "beneficios": ["Benefício 1", "Benefício 2"]
}

###

### PUT - Atualizar plano
PUT http://localhost:3000/planos/1
Content-Type: application/json

{
  "titulo": "Pilates",
  "preco": "Planos flexíveis!",
  "beneficios": ["Mensal (30 dias)", "Quadrimestral (4 meses)", "Semestral (6 meses)"]
}

###

### DELETE - Deletar plano
DELETE http://localhost:3000/planos/1

###

### ==================
### PLANOS DETALHADOS
### ==================

### GET - Buscar planos detalhados
GET http://localhost:3000/planos-detalhados

###

### POST - Criar plano detalhado
POST http://localhost:3000/planos-detalhados
Content-Type: application/json

{
  "titulo": "4x por semana",
  "opcoes": [
    { "nome": "Mensal", "preco": "R$ 450" },
    { "nome": "Semestral", "preco": "R$ 420" }
  ]
}

###

### PUT - Atualizar plano detalhado
PUT http://localhost:3000/planos-detalhados/1
Content-Type: application/json

{
  "titulo": "1x por semana",
  "opcoes": [
    { "nome": "Mensal", "preco": "R$ 180" },
    { "nome": "Quadrimestral", "preco": "R$ 170" },
    { "nome": "Semestral", "preco": "R$ 160" }
  ]
}

